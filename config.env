CONFIG_ENV=config.env

KERNEL_SOURCE=https://github.com/supercutefish/KernelSU-NEXT_Mi-ares
KERNEL_SOURCE_BRANCH=main
KERNEL_CONFIG=ares_user_defconfig
KERNEL_IMAGE_NAME=Image
ARCH=arm64
ADD_LOCALVERSION_TO_FILENAME=false
EXTRA_CMDS="LLVM=1 LLVM_IAS=1 LD=ld.lld"

USE_CUSTOM_CLANG=false
CUSTOM_CMDS="CLANG_TRIPLE=aarch64-linux-gnu-"

# KP 集成（编译前自动执行）
PRE_BUILD_CMDS="
git clone --depth=1 https://github.com/bmax121/KernelPatch.git &&
grep -q KernelPatch drivers/Makefile || echo 'obj-\$(CONFIG_KP) += KernelPatch/' >> drivers/Makefile &&
grep -q KernelPatch drivers/Kconfig || echo 'source \"drivers/KernelPatch/Kconfig\"' >> drivers/Kconfig &&
scripts/config --enable KALLSYMS_ALL &&
scripts/config --enable KP &&
scripts/config --set-str KP_SKEY aa112233 &&
scripts/config --set-str LOCALVERSION -qianjibian
"
CLANG_BRANCH=main
CLANG_VERSION=r530567
